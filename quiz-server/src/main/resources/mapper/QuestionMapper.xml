<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.quiz.mapper.QuestionMapper">

    <resultMap id="questionWithOptionsMap" type="com.quiz.entity.Question">
        <id property="id" column="q_id"/>
        <result property="bankId" column="bank_id"/>
        <result property="type" column="type"/>
        <result property="content" column="content"/>
        <result property="answer" column="answer"/>
        <result property="analysis" column="analysis"/>
        <result property="difficulty" column="difficulty"/>
        <result property="sort" column="q_sort"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
        <collection property="options" ofType="com.quiz.entity.QuestionOption">
            <id property="id" column="opt_id"/>
            <result property="questionId" column="opt_question_id"/>
            <result property="label" column="label"/>
            <result property="content" column="opt_content"/>
            <result property="sort" column="opt_sort"/>
        </collection>
    </resultMap>

    <select id="selectQuestionsByBankIdWithOptions" resultMap="questionWithOptionsMap">
        SELECT
            q.id AS q_id,
            q.bank_id,
            q.type,
            q.content,
            q.answer,
            q.analysis,
            q.difficulty,
            q.sort AS q_sort,
            q.status,
            q.create_time,
            q.update_time,
            q.deleted,
            o.id AS opt_id,
            o.question_id AS opt_question_id,
            o.label,
            o.content AS opt_content,
            o.sort AS opt_sort
        FROM question q
        LEFT JOIN question_option o ON q.id = o.question_id
        WHERE q.bank_id = #{bankId}
          AND q.deleted = 0
        ORDER BY q.sort ASC, q.id ASC, o.sort ASC
    </select>

    <select id="searchQuestions" resultType="com.quiz.entity.Question">
        SELECT id, bank_id, type, content, answer, analysis, difficulty, sort, status, create_time, update_time
        FROM question
        WHERE deleted = 0
          AND content LIKE CONCAT('%', #{keyword}, '%')
        ORDER BY id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByBankId" resultType="int">
        SELECT COUNT(*)
        FROM question
        WHERE bank_id = #{bankId}
          AND deleted = 0
    </select>

</mapper>
