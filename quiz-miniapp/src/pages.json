{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)$": "uview-plus/components/u-$1/u-$1.vue",
      "^uni-(.*)$": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "tab-pages/category/index",
      "style": {
        "navigationBarTitleText": "题库分类"
      }
    },
    {
      "path": "pages/ai/index",
      "style": {
        "navigationBarTitleText": "学习助手"
      }
    },
    {
      "path": "tab-pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages/category",
      "pages": [
        {
          "path": "detail",
          "style": {
            "navigationBarTitleText": "分类题库"
          }
        }
      ]
    },
    {
      "root": "pages/bank",
      "pages": [
        {
          "path": "list",
          "style": {
            "navigationBarTitleText": "题库列表"
          }
        },
        {
          "path": "detail",
          "style": {
            "navigationBarTitleText": "题库详情"
          }
        }
      ]
    },
    {
      "root": "pages/practice",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "练习"
          }
        }
      ]
    },
    {
      "root": "pages/exam",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "模拟考试"
          }
        },
        {
          "path": "result",
          "style": {
            "navigationBarTitleText": "考试结果"
          }
        },
        {
          "path": "list",
          "style": {
            "navigationBarTitleText": "考试记录"
          }
        }
      ]
    },
    {
      "root": "pages/search",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "搜索"
          }
        }
      ]
    },
    {
      "root": "pages/favorite",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "收藏"
          }
        }
      ]
    },
    {
      "root": "pages/wrong",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "错题本"
          }
        }
      ]
    },
    {
      "root": "pages/record",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "做题记录"
          }
        },
        {
          "path": "detail",
          "style": {
            "navigationBarTitleText": "记录详情"
          }
        }
      ]
    },
    {
      "root": "pages/vip",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "功能说明"
          }
        },
        {
          "path": "orders",
          "style": {
            "navigationBarTitleText": "提交记录"
          }
        },
        {
          "path": "success",
          "style": {
            "navigationBarTitleText": "提交成功"
          }
        }
      ]
    },
    {
      "root": "pages/mine",
      "pages": [
        {
          "path": "profile",
          "style": {
            "navigationBarTitleText": "编辑资料"
          }
        },
        {
          "path": "settings",
          "style": {
            "navigationBarTitleText": "设置"
          }
        }
      ]
    },
    {
      "root": "pages/auth",
      "pages": [
        {
          "path": "complete-profile",
          "style": {
            "navigationBarTitleText": "完善资料"
          }
        },
        {
          "path": "service-agreement",
          "style": {
            "navigationBarTitleText": "用户服务协议"
          }
        },
        {
          "path": "privacy-policy",
          "style": {
            "navigationBarTitleText": "隐私政策"
          }
        }
      ]
    }
  ],
  "tabBar": {
    "color": "#9AA0A6",
    "selectedColor": "#e53935",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home_active.png"
      },
      {
        "pagePath": "tab-pages/category/index",
        "text": "题库",
        "iconPath": "static/tabbar/category.png",
        "selectedIconPath": "static/tabbar/category_active.png"
      },
      {
        "pagePath": "pages/ai/index",
        "text": "学习助手",
        "iconPath": "static/tabbar/ai.png",
        "selectedIconPath": "static/tabbar/ai_active.png"
      },
      {
        "pagePath": "tab-pages/mine/index",
        "text": "我的",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine_active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "Quiz",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F6F7FB",
    "backgroundTextStyle": "light"
  }
}
